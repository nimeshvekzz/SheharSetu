<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- Main surface of avatar background -->
    <solid android:color="@android:color/white" />

    <!-- Soft green outline -->
    <stroke
        android:width="1dp"
        android:color="@color/colorPrimaryLight" />

    <!-- Small inner spacing so the image doesn’t touch the border -->
    <padding
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp" />

</shape>
