<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Focused state - darker border -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="28dp"/>
            <solid android:color="#F0FFFFFF"/>
            <stroke 
                android:width="2dp" 
                android:color="@color/colorPrimary"/>
            <padding 
                android:left="14dp" 
                android:right="14dp"
                android:top="0dp"
                android:bottom="0dp"/>
        </shape>
    </item>
    
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp"/>
            <solid android:color="#E0FFFFFF"/>
            <stroke 
                android:width="1dp" 
                android:color="#40000000"/>
            <padding 
                android:left="14dp" 
                android:right="14dp"
                android:top="0dp"
                android:bottom="0dp"/>
        </shape>
    </item>
    
</selector>
