<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Dark gradient background -->
    <item>
        <shape>
            <gradient
                android:startColor="#020617"
                android:centerColor="#111827"
                android:endColor="#0F172A"
                android:angle="135" />
        </shape>
    </item>

    <!-- Subtle overlay to match app style -->
    <item>
        <shape>
            <corners android:radius="0dp" />
            <padding
                android:left="0dp"
                android:top="0dp"
                android:right="0dp"
                android:bottom="0dp" />
        </shape>
    </item>
</layer-list>
