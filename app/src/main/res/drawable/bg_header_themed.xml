<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base gradient matching theme -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#7A8D70"
                android:centerColor="#96A78D"
                android:endColor="#A8BDA0"
                android:angle="135"/>
        </shape>
    </item>
    
    <!-- Subtle wave/decoration at bottom -->
    <item android:gravity="bottom">
        <shape android:shape="rectangle">
            <size android:height="8dp"/>
            <gradient
                android:startColor="#2096A78D"
                android:endColor="#00FFFFFF"
                android:type="linear"
                android:angle="270"/>
        </shape>
    </item>
</layer-list>
