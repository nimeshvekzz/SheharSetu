<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/colorBackgroundSoft"
    app:strokeWidth="1dp"
    app:strokeColor="@color/colorPrimaryLight">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Label with icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_camera_24"
                android:tint="@color/colorPrimary"
                android:contentDescription="Photos" />

            <TextView
                android:id="@+id/tvLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Add Photos"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/colorTextPrimary" />

            <TextView
                android:id="@+id/tvRequired"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="*"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#E53935"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Helper text -->
        <TextView
            android:id="@+id/tvHelper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add clear, well-lit photos to attract buyers"
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="6dp" />

        <!-- Tip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_tip_box"
            android:padding="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_info_outline"
                android:tint="@color/colorPrimary"
                android:contentDescription="Tip" />

            <TextView
                android:id="@+id/tvTip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="The first photo will be shown as your main image. Tap any photo to change or delete it."
                android:textSize="11sp"
                android:textColor="@color/colorTextSecondary" />
        </LinearLayout>

        <!-- Photos RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPhotosStrip"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginTop="12dp"
            android:overScrollMode="never"
            android:clipToPadding="false" />

        <!-- Photo count status -->
        <TextView
            android:id="@+id/tvPhotoStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="8dp"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
