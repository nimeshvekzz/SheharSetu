<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="130dp"
    android:layout_margin="6dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="14dp"
    app:cardElevation="6dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/premium_surface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp">

        <!-- ===== BACKGROUND IMAGE/ICON ===== -->
        <!-- We use a subtle circle behind the icon for a premium look -->
        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_circle_surface"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp">

            <ImageView
                android:id="@+id/imgIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:scaleType="centerInside"
                android:contentDescription="@null"
                app:tint="@color/colorPrimary" />

        </FrameLayout>

        <!-- ===== CATEGORY NAME ===== -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="@color/premium_text_main"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:lineSpacingMultiplier="1.1"
            app:layout_constraintTop_toBottomOf="@id/iconContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ===== BADGE (If applicable) ===== -->
        <FrameLayout
            android:id="@+id/badge"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:visibility="gone"
            android:background="@drawable/bg_check_badge_premium"
            app:layout_constraintTop_toTopOf="@id/iconContainer"
            app:layout_constraintEnd_toEndOf="@id/iconContainer"
            android:layout_marginTop="-4dp"
            android:layout_marginEnd="-4dp">

            <ImageView
                android:id="@+id/ivTick"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="3dp"
                android:src="@drawable/ic_check_24"
                app:tint="@android:color/white" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
