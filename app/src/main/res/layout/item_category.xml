<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_marginEnd="16dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackgroundBorderless">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/catCard"
        android:layout_width="66dp"
        android:layout_height="66dp"
        app:cardCornerRadius="33dp"
        app:cardElevation="0dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="@color/premium_divider"
        app:cardBackgroundColor="@color/premium_surface">

        <ImageView
            android:id="@+id/catIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="18dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_placeholder_circle"
            app:tint="@color/colorPrimary" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/catTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Category"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/premium_text_main"
        android:gravity="center"
        android:maxWidth="84dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:alpha="0.8"/>

</LinearLayout>
