<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fitsSystemWindows="false">

    <!-- ═══════════ SOLID BLACK TOP STATUS BAR ═══════════ -->
    <View
        android:id="@+id/viewStatusBarBackground"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:background="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══════════ FIXED TOOLBAR ═══════════ -->
    <LinearLayout
        android:id="@+id/appBarLayoutFixed"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#063940"
        android:elevation="4dp"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/viewStatusBarBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Using the original toolbar ID on the ImageButton so the Java onClick fires properly -->
        <ImageButton
            android:id="@+id/toolbar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back_24"
            android:contentDescription="Back"
            app:tint="@android:color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="Seller Profile"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- ═══════════ SCROLLING CONTENT ═══════════ -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/appBarLayoutFixed"
        app:layout_constraintBottom_toTopOf="@id/viewNavBarBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="48dp">

            <!-- ─── Unified Built-In Hero Header ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_profile_header_gradient_rounded"
                android:paddingTop="32dp"
                android:paddingBottom="56dp"
                android:elevation="4dp">

                <!-- ─── Avatar Container ─── -->
                <FrameLayout
                    android:layout_width="104dp"
                    android:layout_height="104dp"
                    android:elevation="4dp"
                  >

                    <!-- Geometric Letter Avatar (Base) -->
                    <TextView
                        android:id="@+id/tvAvatarLetter"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_avatar_ring"
                        android:gravity="center"
                        android:text="-"
                        android:textAllCaps="true"
                        android:textColor="@android:color/white"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif"
                        android:includeFontPadding="false" />

                    <!-- Real Image Upload Overlay (Overlaps if it exists) -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivSellerAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                        app:strokeColor="@android:color/white"
                        app:strokeWidth="3dp"
                        android:padding="2dp"
                        android:visibility="invisible" />
                </FrameLayout>

                <!-- Seller Name -->
                <TextView
                    android:id="@+id/tvSellerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Seller Name"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <!-- Trust Badge: Member Since -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_chip_place_type"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_verified_badge"
                        app:tint="#063940"
                        android:contentDescription="Verified"/>

                    <TextView
                        android:id="@+id/tvMemberSince"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Member since Jan 2024"
                        android:textColor="#063940"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- ─── Details & Actions Area ─── -->
            <!-- Overlaps the bottom of the gradient slightly for a premium, connected feel -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginTop="-24dp"
                android:elevation="6dp">

                <!-- MAIN ACTIONS CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <!-- Call Action -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCall"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="Call"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="#063940"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:strokeColor="#063940"
                            app:strokeWidth="1.5dp"
                            app:icon="@drawable/ic_phone_24px"
                            app:iconTint="#063940"
                            app:iconGravity="textStart"
                            app:iconPadding="8dp"
                            app:cornerRadius="24dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                        <!-- WhatsApp Action -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnWhatsapp"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="WhatsApp"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/white"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="#25D366"
                            app:icon="@drawable/ic_contact_whatsapp"
                            app:iconTint="@android:color/white"
                            app:iconGravity="textStart"
                            app:iconPadding="8dp"
                            app:cornerRadius="24dp"
                            style="@style/Widget.MaterialComponents.Button"/>

                        <!-- Location Action -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLocation"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="8dp"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="#063940"
                            app:icon="@drawable/ic_location_24px"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconTint="@color/white"
                            app:cornerRadius="24dp"
                            style="@style/Widget.MaterialComponents.Button"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ACTIVE LISTINGS HEADER -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:layout_marginBottom="12dp">
                    
                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="#063940"
                        android:layout_marginEnd="12dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Active Listings"
                        android:textColor="#1B1F24"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- LISTINGS GRID -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSellerListings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2"
                    tools:listitem="@layout/item_product"
                    tools:itemCount="4" />

                <!-- EMPTY STATE -->
                <LinearLayout
                    android:id="@+id/tvNoListings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="48dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/ic_placeholder_circle"
                        app:tint="#D1D5DB"
                        android:alpha="0.5"
                        android:contentDescription="No listings" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="No active listings currently"
                        android:textColor="#6B7280"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- LOADING PROGRESS -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/appBarLayoutFixed"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══════════ SOLID BLACK BOTTOM NAV BAR ═══════════ -->
    <View
        android:id="@+id/viewNavBarBackground"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
