<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/premium_bg"
    android:fitsSystemWindows="false">

    <!-- ═══════════ SOLID BLACK TOP STATUS BAR ═══════════ -->
    <View
        android:id="@+id/viewStatusBarBackground"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══════════ FIXED TOOLBAR ═══════════ -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/teal_premium"
        android:elevation="0dp"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:navigationIconTint="#FFFFFF"
        app:title="My ads"
        app:titleTextColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/viewStatusBarBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══════════ HEADER METRICS DASHBOARD ═══════════ -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Metrics Cards Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:weightSum="3"
            android:baselineAligned="false">

            <!-- Card: Total Ads -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#10000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="18dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvTotalAdsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#004D40"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Total ads"
                        android:textSize="12sp"
                        android:textColor="#6B7280"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Active -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#10000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="18dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvActiveAdsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#004D40"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Active"
                        android:textSize="12sp"
                        android:textColor="#6B7280"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Sold -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#10000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="18dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvSoldAdsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#004D40"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Sold"
                        android:textSize="12sp"
                        android:textColor="#6B7280"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Filter Pills ScrollView -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:clipToPadding="false"
            android:paddingHorizontal="12dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="4dp">

                <!-- Chip: All ads -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/chipAllAds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E5E7EB">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="All ads"
                        android:textColor="#4B5563"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Chip: Active -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/chipActiveAds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E5E7EB">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="Active"
                        android:textColor="#4B5563"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Chip: Sold -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/chipSoldAds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E5E7EB">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="Sold"
                        android:textColor="#4B5563"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Chip: Paused -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/chipPausedAds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E5E7EB">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="Paused"
                        android:textColor="#4B5563"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tvListingsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="16dp"
            android:text="6 listings"
            android:textColor="#004D40"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- ═══════════ CONTENT (RECYCLER VIEW) ═══════════ -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toTopOf="@id/viewNavBarBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- SwipeRefreshLayout wrapping RecyclerView -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMyAds"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="12dp"
                android:paddingBottom="48dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- Empty State -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEmptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="32dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp">

                <ImageView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:alpha="0.2"
                    android:src="@drawable/ic_list_24"
                    android:contentDescription="No ads"
                    app:tint="@color/premium_text_sub" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="No ads yet"
                    android:textColor="@color/premium_text_main"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Post your first ad and it will appear here"
                    android:textColor="@color/premium_text_sub"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPostAd"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:layout_marginTop="32dp"
                    android:text="Post Ad"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="@color/colorPrimary"
                    app:cornerRadius="26dp"
                    app:icon="@drawable/ic_send_24"
                    app:iconGravity="textStart"
                    app:iconTint="#FFFFFF" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <!-- ═══════════ SOLID BLACK BOTTOM NAV BAR ═══════════ -->
    <View
        android:id="@+id/viewNavBarBackground"
        android:layout_width="0dp"
        android:layout_height="20dp"
        android:background="#000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
