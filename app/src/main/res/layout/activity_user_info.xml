<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootUserInfo"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="40dp"
            android:paddingBottom="120dp">

            <!-- Language Badge - Premium Style -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/colorPrimaryLight"
                app:strokeColor="@color/colorPrimaryMedium"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/tvLangBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Language: English"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextPrimary"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:textSize="12sp"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Header with Premium Typography -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Complete Your Profile"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary"
                android:letterSpacing="0.02"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Please provide your details to continue."
                android:textSize="14sp"
                android:textColor="@color/colorTextSecondary"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="2dp"/>

            <!-- Premium Card Panel -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="8dp"
                app:cardCornerRadius="22dp"
                app:cardBackgroundColor="@color/colorSurface"
                app:strokeColor="@color/colorDivider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <!-- Section Header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Personal Information"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tell us a bit about yourself."
                        android:textSize="12sp"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="16dp"/>

                    <!-- Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Name"
                        app:hintTextColor="@color/colorTextSecondary"
                        app:boxBackgroundColor="@color/colorSurface"
                        app:boxStrokeColor="@color/colorDivider"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:startIconDrawable="@drawable/ic_person_24px"
                        app:startIconTint="@color/colorPrimary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/colorTextPrimary"
                            android:singleLine="true"
                            android:textSize="16sp"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Surname -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Surname"
                        app:hintTextColor="@color/colorTextSecondary"
                        app:boxBackgroundColor="@color/colorSurface"
                        app:boxStrokeColor="@color/colorDivider"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:startIconDrawable="@drawable/ic_person_24px"
                        app:startIconTint="@color/colorPrimary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSurname"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/colorTextPrimary"
                            android:singleLine="true"
                            android:textSize="16sp"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Mobile -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Mobile number"
                        app:hintTextColor="@color/colorTextSecondary"
                        app:boxBackgroundColor="@color/colorSurface"
                        app:boxStrokeColor="@color/colorDivider"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:startIconDrawable="@drawable/ic_phone_24px"
                        app:startIconTint="@color/colorPrimary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMobile"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/colorTextPrimary"
                            android:singleLine="true"
                            android:inputType="phone"
                            android:maxLength="10"
                            android:textSize="16sp"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Divider between sections -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="22dp"
                        android:layout_marginBottom="18dp"
                        android:background="@color/colorDivider"/>

                    <!-- Location Section Header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Location Details"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="This helps us show relevant content around you."
                        android:textSize="12sp"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="16dp"/>

                    <!-- State -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Select State"
                        app:hintTextColor="@color/colorTextSecondary"
                        app:boxBackgroundColor="@color/colorSurface"
                        app:boxStrokeColor="@color/colorDivider"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:startIconDrawable="@drawable/ic_location_24px"
                        app:startIconTint="@color/colorPrimary">

                        <AutoCompleteTextView
                            android:id="@+id/spState"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/colorTextPrimary"
                            android:inputType="none"
                            android:textSize="16sp"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- District -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Select District"
                        app:hintTextColor="@color/colorTextSecondary"
                        app:boxBackgroundColor="@color/colorSurface"
                        app:boxStrokeColor="@color/colorDivider"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:startIconDrawable="@drawable/ic_map_24px"
                        app:startIconTint="@color/colorPrimary">

                        <AutoCompleteTextView
                            android:id="@+id/spDistrict"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/colorTextPrimary"
                            android:inputType="none"
                            android:textSize="16sp"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Village / City Selection -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Location Type"
                        android:textSize="14sp"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/rgPlaceType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/rbVillage"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Village"
                            app:chipBackgroundColor="@color/colorPrimaryLight"
                            app:chipStrokeColor="@color/colorPrimary"
                            app:chipStrokeWidth="1dp"
                            app:checkedIcon="@null"
                            app:chipSurfaceColor="@color/colorSurface"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/rbCity"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="City"
                            app:chipBackgroundColor="@color/colorPrimaryLight"
                            app:chipStrokeColor="@color/colorPrimary"
                            app:chipStrokeWidth="1dp"
                            app:checkedIcon="@null"
                            app:chipSurfaceColor="@color/colorSurface"/>
                    </com.google.android.material.chip.ChipGroup>

                    <!-- Place name -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Village / City Name"
                        app:hintTextColor="@color/colorTextSecondary"
                        app:boxBackgroundColor="@color/colorSurface"
                        app:boxStrokeColor="@color/colorDivider"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:startIconDrawable="@drawable/ic_place_24px"
                        app:startIconTint="@color/colorPrimary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPlaceName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/colorTextPrimary"
                            android:singleLine="true"
                            android:textSize="16sp"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Address -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Full address"
                        app:hintTextColor="@color/colorTextSecondary"
                        app:boxBackgroundColor="@color/colorSurface"
                        app:boxStrokeColor="@color/colorDivider"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:startIconDrawable="@drawable/ic_home_24px"
                        app:startIconTint="@color/colorPrimary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAddress"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:gravity="top|start"
                            android:inputType="textMultiLine"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="16sp"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Pincode -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Pincode"
                        app:hintTextColor="@color/colorTextSecondary"
                        app:boxBackgroundColor="@color/colorSurface"
                        app:boxStrokeColor="@color/colorDivider"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:startIconDrawable="@drawable/ic_pin_24px"
                        app:startIconTint="@color/colorPrimary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPincode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="6"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="16sp"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Terms -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/colorPrimaryLight">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="14dp"
                            android:gravity="center_vertical">

                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/cbTerms"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:buttonTint="@color/colorPrimary"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="I agree to the Terms and Conditions"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="14sp"
                                android:lineSpacingExtra="2dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Login Link -->
            <TextView
                android:id="@+id/tvLoginLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Already have an account? Log in"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:textSize="15sp"
                android:paddingVertical="8dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Premium Sticky CTA -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="0dp"
        app:cardCornerRadius="0dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="@color/colorSurface"
        app:strokeColor="@color/colorDivider"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinue"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Continue"
                android:backgroundTint="@color/colorPrimary"
                android:textColor="@color/colorSurface"
                android:enabled="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="18dp"
                app:icon="@drawable/ic_arrow_forward_24px"
                app:iconGravity="textEnd"
                app:iconTint="@color/colorSurface"
                app:rippleColor="@color/colorPrimaryMedium"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
