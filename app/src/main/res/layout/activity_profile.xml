<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:id="@+id/rootProfile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackgroundSoft"
    android:fitsSystemWindows="true">

    <!-- Top App Bar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@color/colorPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_back_24"
            android:contentDescription="@string/app_name"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Profile"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Small divider under toolbar for better separation -->
    <View
        android:id="@+id/toolbarShadow"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/colorDivider"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbarShadow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="top">

            <!-- Header card: Avatar + basic info (View + Edit) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProfileMain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="22dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <!-- Avatar circle -->
                    <TextView
                        android:id="@+id/tvAvatarLetter"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_avatar_circle"
                        android:gravity="center"
                        android:text=""
                        android:textAllCaps="true"
                        android:textColor="@android:color/white"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- VIEW HEADER -->
                        <LinearLayout
                            android:id="@+id/sectionViewHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvFullName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.03" />

                            <TextView
                                android:id="@+id/tvPhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text=""
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvPlaceTypeChip"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="5dp"
                                android:paddingBottom="5dp"
                                android:background="@drawable/bg_chip_place_type"
                                android:text=""
                                android:visibility="gone"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- EDIT HEADER -->
                        <LinearLayout
                            android:id="@+id/sectionEditHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            android:layout_marginTop="2dp">

                            <!-- Full name -->
                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Full name"
                                app:boxBackgroundColor="@color/colorSurface"
                                app:boxStrokeColor="@color/colorPrimaryMedium"
                                app:boxStrokeWidth="1dp"
                                app:hintTextColor="@color/colorTextPrimary">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etFullName"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="textPersonName"
                                    android:textColor="@color/colorTextPrimary"
                                    android:textColorHint="@color/colorTextSecondary" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- Phone -->
                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:hint="Phone"
                                app:boxBackgroundColor="@color/colorSurface"
                                app:boxStrokeColor="@color/colorPrimaryMedium"
                                app:boxStrokeWidth="1dp"
                                app:hintTextColor="@color/colorTextPrimary">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etPhone"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="phone"
                                    android:maxLength="10"
                                    android:textColor="@color/colorTextPrimary"
                                    android:textColorHint="@color/colorTextSecondary" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- Place type DROPDOWN (Village / City) -->
                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:hint="Place type"
                                app:endIconMode="dropdown_menu"
                                app:boxBackgroundColor="@color/colorSurface"
                                app:boxStrokeColor="@color/colorPrimaryMedium"
                                app:boxStrokeWidth="1dp"
                                app:hintTextColor="@color/colorTextPrimary">

                                <AutoCompleteTextView
                                    android:id="@+id/etPlaceType"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="none"
                                    android:focusable="false"
                                    android:clickable="true"
                                    android:textColor="@color/colorTextPrimary"
                                    android:textColorHint="@color/colorTextSecondary" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section title for details (VIEW mode) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile details"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextSecondary"
                android:letterSpacing="0.04"
                android:layout_marginBottom="8dp" />

            <!-- VIEW MODE DETAILS (2 separate cards) -->
            <LinearLayout
                android:id="@+id/sectionViewDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Contact Details Card (VIEW) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardContactView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardCornerRadius="18dp"
                    app:cardUseCompatPadding="true"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Contact details"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="6dp"
                            android:background="@color/colorDivider" />

                        <!-- Surname -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="10dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Surname"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvSurnameValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Phone (view only) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Phone"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvContactPhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="14sp" />
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Address & Location Card (VIEW) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAddressView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardCornerRadius="18dp"
                    app:cardUseCompatPadding="true"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Address and location"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="6dp"
                            android:background="@color/colorDivider" />

                        <!-- Address line -->
                        <TextView
                            android:id="@+id/tvAddressLine"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text=""
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="14sp" />

                        <!-- Village -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="10dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Village"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvVillage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- District -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="District"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvDistrict"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- State -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="State"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvState"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Pincode -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Pincode"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvPincode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="14sp" />
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Settings Card (Language, etc.) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardCornerRadius="18dp"
                    app:cardUseCompatPadding="true"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Settings"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="6dp"
                            android:background="@color/colorDivider" />

                        <!-- Language Row -->
                        <LinearLayout
                            android:id="@+id/layoutLanguage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="14dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_language_24"
                                app:tint="@color/colorTextSecondary"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="16dp"
                                android:text="Language"
                                android:textSize="15sp"
                                android:textColor="@color/colorTextPrimary"/>

                            <TextView
                                android:id="@+id/tvLanguageValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="English"
                                android:textSize="14sp"
                                android:textColor="@color/colorPrimary"/>

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginStart="8dp"
                                android:src="@drawable/ic_arrow_forward_24"
                                app:tint="@color/colorTextSecondary"/>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>



            <!-- EDIT section title -->
            <TextView
                android:id="@+id/tvEditSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit details"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextSecondary"
                android:letterSpacing="0.04"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- EDIT MODE DETAILS (2 separate cards, same palette) -->
            <LinearLayout
                android:id="@+id/sectionEditDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Contact Details Card (EDIT) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardCornerRadius="18dp"
                    app:cardUseCompatPadding="true"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Contact details"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="6dp"
                            android:background="@color/colorDivider" />

                        <!-- Surname -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:hint="Surname"
                            app:boxBackgroundColor="@color/colorSurface"
                            app:boxStrokeColor="@color/colorPrimaryMedium"
                            app:boxStrokeWidth="1dp"
                            app:hintTextColor="@color/colorTextPrimary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSurname"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPersonName"
                                android:textColor="@color/colorTextPrimary"
                                android:textColorHint="@color/colorTextSecondary" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Address & Location Card (EDIT) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardCornerRadius="18dp"
                    app:cardUseCompatPadding="true"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Address and location"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="6dp"
                            android:background="@color/colorDivider" />

                        <!-- Address -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:hint="Address"
                            app:boxBackgroundColor="@color/colorSurface"
                            app:boxStrokeColor="@color/colorPrimaryMedium"
                            app:boxStrokeWidth="1dp"
                            app:hintTextColor="@color/colorTextPrimary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAddress"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPostalAddress"
                                android:textColor="@color/colorTextPrimary"
                                android:textColorHint="@color/colorTextSecondary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Village -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="Village"
                            app:boxBackgroundColor="@color/colorSurface"
                            app:boxStrokeColor="@color/colorPrimaryMedium"
                            app:boxStrokeWidth="1dp"
                            app:hintTextColor="@color/colorTextPrimary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etVillage"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapWords"
                                android:textColor="@color/colorTextPrimary"
                                android:textColorHint="@color/colorTextSecondary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- District -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="District"
                            app:boxBackgroundColor="@color/colorSurface"
                            app:boxStrokeColor="@color/colorPrimaryMedium"
                            app:boxStrokeWidth="1dp"
                            app:hintTextColor="@color/colorTextPrimary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDistrict"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapWords"
                                android:textColor="@color/colorTextPrimary"
                                android:textColorHint="@color/colorTextSecondary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- State -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="State"
                            app:boxBackgroundColor="@color/colorSurface"
                            app:boxStrokeColor="@color/colorPrimaryMedium"
                            app:boxStrokeWidth="1dp"
                            app:hintTextColor="@color/colorTextPrimary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etState"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapWords"
                                android:textColor="@color/colorTextPrimary"
                                android:textColorHint="@color/colorTextSecondary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Pincode -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="Pincode"
                            app:boxBackgroundColor="@color/colorSurface"
                            app:boxStrokeColor="@color/colorPrimaryMedium"
                            app:boxStrokeWidth="1dp"
                            app:hintTextColor="@color/colorTextPrimary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPincode"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textColor="@color/colorTextPrimary"
                                android:textColorHint="@color/colorTextSecondary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Save button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveProfile"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Save changes"
                            android:textAllCaps="false"
                            android:textStyle="bold"
                            android:textColor="@android:color/white"
                            android:backgroundTint="@color/colorPrimary" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Floating Edit button at bottom-right -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnEditToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Edit profile"
        android:src="@drawable/ic_edit_24"
        app:tint="@android:color/white"
        app:backgroundTint="@color/colorPrimary"
        app:useCompatPadding="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
