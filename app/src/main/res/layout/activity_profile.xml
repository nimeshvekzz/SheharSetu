<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootProfile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fitsSystemWindows="false">

    <!-- ═══════════ SOLID BLACK TOP STATUS BAR ═══════════ -->
    <!-- The user strictly requested absolute black without any gaps -->
    <View
        android:id="@+id/viewStatusBarBg"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:background="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══════════ FIXED TOOLBAR ═══════════ -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#063940"
        android:elevation="4dp"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/viewStatusBarBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back_24"
            android:contentDescription="Back"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="My Profile"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <View
        android:id="@+id/toolbarShadow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══════════ SCROLLING CONTENT ═══════════ -->
    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/viewNavBarBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="100dp">

            <!-- ─── Unified Built-In Hero Header ─── -->
            <!-- ALL top profile data lives securely in this gradient block.
                 This eliminates ALL awkward spacing and overlapping issues. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_profile_header_gradient_rounded"
                android:paddingTop="32dp"
                android:paddingBottom="56dp"
                android:elevation="4dp">

                <!-- ─── Perfect Geometric Avatar Ring ─── -->
                <TextView
                    android:id="@+id/tvAvatarLetter"
                    android:layout_width="104dp"
                    android:layout_height="104dp"
                    android:background="@drawable/bg_avatar_ring"
                    android:gravity="center"
                    android:text="-"
                    android:textAllCaps="true"
                    android:textColor="@android:color/white"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif"
                    android:includeFontPadding="false"
                    android:elevation="4dp"
                    android:outlineProvider="background" />

                <!-- Full Name -->
                <TextView
                    android:id="@+id/tvFullName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <!-- Phone number -->
                <TextView
                    android:id="@+id/tvPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="-"
                    android:textColor="#E5E7EB"
                    android:textSize="15sp"
                    android:letterSpacing="0.05" />

                <!-- Place Type Chip -->
                <TextView
                    android:id="@+id/tvPlaceTypeChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:background="@drawable/bg_chip_place_type"
                    android:text="-"
                    android:visibility="gone"
                    android:textColor="#063940"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
            </LinearLayout>

            <!-- ─── Details Cards Area ─── -->
            <!-- Overlaps the bottom of the gradient slightly for a premium, connected feel -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginTop="-24dp"
                android:elevation="6dp">

                <!-- CONTACT CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            <LinearLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_section_icon"
                                android:gravity="center"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_contact_phone"
                                    app:tint="#195E63" />
                            </LinearLayout>
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Contact Information"
                                android:textColor="#1B1F24"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Surname -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_row_item"
                            android:gravity="center_vertical"
                            android:padding="16dp"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Surname"
                                android:textColor="#6B7280"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/tvSurnameValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="#1B1F24"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Phone -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_row_item"
                            android:gravity="center_vertical"
                            android:padding="16dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Phone"
                                android:textColor="#6B7280"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/tvContactPhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="#1B1F24"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ADDRESS CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            <LinearLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_section_icon"
                                android:gravity="center"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_location"
                                    app:tint="#195E63" />
                            </LinearLayout>
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Location Details"
                                android:textColor="#1B1F24"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Address Line -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_row_item"
                            android:padding="16dp"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Address"
                                android:textColor="#6B7280"
                                android:textSize="13sp"
                                android:layout_marginBottom="4dp" />
                            <TextView
                                android:id="@+id/tvAddressLine"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="#1B1F24"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:lineSpacingExtra="4dp" />
                        </LinearLayout>

                        <!-- Village -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_row_item"
                            android:gravity="center_vertical"
                            android:padding="16dp"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Village"
                                android:textColor="#6B7280"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/tvVillage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="#1B1F24"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- District -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_row_item"
                            android:gravity="center_vertical"
                            android:padding="16dp"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="District"
                                android:textColor="#6B7280"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/tvDistrict"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="#1B1F24"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- State -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_row_item"
                            android:gravity="center_vertical"
                            android:padding="16dp"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="State"
                                android:textColor="#6B7280"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/tvState"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="#1B1F24"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Pincode -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_row_item"
                            android:gravity="center_vertical"
                            android:padding="16dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Pincode"
                                android:textColor="#6B7280"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/tvPincode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="#1B1F24"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- SETTINGS CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Language Row -->
                        <LinearLayout
                            android:id="@+id/layoutLanguage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="20dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">
                            <LinearLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_section_icon"
                                android:gravity="center"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_language_24"
                                    app:tint="#195E63" />
                            </LinearLayout>
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="App Language"
                                android:textSize="16sp"
                                android:textColor="#1B1F24"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvLanguageValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="English"
                                android:textSize="14sp"
                                android:textColor="#6B7280"
                                android:layout_marginEnd="8dp" />
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_arrow_forward_24"
                                app:tint="#6B7280" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ═══════════ SOLID BLACK BOTTOM NAV BAR ═══════════ -->
    <View
        android:id="@+id/viewNavBarBg"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══════════ FLOATING EDIT BUTTON ═══════════ -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnEditToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="Edit Profile"
        android:src="@drawable/ic_edit_24"
        app:tint="@android:color/white"
        app:backgroundTint="#195E63"
        app:useCompatPadding="false"
        app:elevation="6dp"
        app:layout_constraintBottom_toTopOf="@id/viewNavBarBg"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
