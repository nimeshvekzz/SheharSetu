<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingTop="32dp"
    android:paddingBottom="18dp"
    android:gravity="center_vertical"
    android:background="@drawable/nav_header_bg"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackgroundBorderless">

    <!-- avatar row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivProfile"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_person_24"
            android:background="@drawable/circle_white"
            android:padding="14dp"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vansh Mandanka"
                android:textSize="18sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"
                android:letterSpacing="0.02"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/tvUserPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="+91 6354355617"
                android:textSize="13sp"
                android:textColor="#E6FFFFFF"
                android:layout_marginTop="2dp"/>

            <!-- small app tagline -->
            <TextView
                android:id="@+id/tvUserTagline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SheharSetu · Local. Simple. Smart."
                android:textSize="11sp"
                android:textColor="#B3FFFFFF"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- tiny edit icon on the right (kept same id) -->
        <ImageView
            android:id="@+id/ivEdit"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_edit_24"
            android:contentDescription="@null"
            android:background="@drawable/bg_icon_tap"
            android:padding="6dp" />
    </LinearLayout>

</LinearLayout>
